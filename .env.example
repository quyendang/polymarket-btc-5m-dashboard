# Copy to .env and fill in. NEVER commit the real .env.

# --- Polymarket wallet / auth ---
POLY_PRIVATE_KEY=0x...your_private_key...
# Fill these three from `python setup_creds.py`:
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
# The Deposit Wallet that holds your Polymarket pUSD collateral.
POLY_FUNDER_ADDRESS=0x...your_deposit_wallet...
# 3 = Deposit Wallet (default). 0 works only for Polymarket-allowlisted EOAs.
# Legacy proxy/Safe types 1 and 2 are rejected by CLOB V2.
POLY_SIGNATURE_TYPE=3

# --- Browser-free claim worker ---
# Claim only needs the signer, Deposit Wallet and one relayer auth method.
# The three POLY_API_* values above are optional here; when all are empty the
# official SDK derives CLOB credentials from POLY_PRIVATE_KEY at startup.
# Create Builder credentials in Polymarket's Builder program, or configure the
# alternative RELAYER key/address pair. Never expose these to the web service.
POLY_BUILDER_API_KEY=
POLY_BUILDER_API_SECRET=
POLY_BUILDER_API_PASSPHRASE=
# Recommended for an existing account: create this under Polymarket Settings >
# API Keys > Relayer API Keys. ADDRESS is the Signer Address shown with the key.
POLY_RELAYER_API_KEY=
POLY_RELAYER_ADDRESS=
AUTO_CLAIM_ENABLED=false
CLAIM_POLL_SECONDS=5
CLAIM_RESOLUTION_RETRY_SECONDS=30
CLAIM_RETRY_BASE_SECONDS=15
CLAIM_MAX_ATTEMPTS=5
CLAIM_RECONCILE_SECONDS=600
POLY_RELAYER_URL=https://relayer-v2.polymarket.com
POLY_DATA_HOST=https://data-api.polymarket.com
POLYGON_RPC_URL=https://polygon.drpc.org

# --- Bankroll / mode ---
# Keep STARTING_BANKROLL high enough that safe mode's 25% stake is >= MIN_BET.
# With MIN_BET=1.0, STARTING_BANKROLL=20.0 makes safe mode stake $5.00.
STARTING_BANKROLL=20.0
MIN_BET=1.0
BOT_MODE=safe

# --- Dashboard / Railway ---
APP_ENV=development
DATABASE_URL=sqlite:///./polymarket_dashboard.db
# Production must use an Argon2 hash. Generate with:
# python -m app.security "your-password"
DASHBOARD_PASSWORD_HASH=
DASHBOARD_DEV_PASSWORD=admin
SESSION_SECRET=replace-with-at-least-32-random-characters
LIVE_TRADING_ENABLED=false
SERVICE_ROLE=web
TZ=Asia/Ho_Chi_Minh

# --- Endpoints ---
# Binance main API is geo-blocked in the US (HTTP 451); use the public market-data mirror.
BINANCE_BASE=https://data-api.binance.vision
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com

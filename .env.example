# Copy to .env and fill in. NEVER commit the real .env.

# --- Polymarket wallet / auth ---
POLY_PRIVATE_KEY=0x...your_private_key...
# Fill these three from `python setup_creds.py`:
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
# The address that HOLDS your USDC (proxy wallet for Magic/email logins).
POLY_FUNDER_ADDRESS=0x...your_proxy_wallet...
# 1 = email/Magic proxy (default), 0 = EOA, 2 = Gnosis Safe, 3 = EIP-1271 wallet
POLY_SIGNATURE_TYPE=1

# --- Bankroll / mode ---
# Keep STARTING_BANKROLL high enough that safe mode's 25% stake is >= MIN_BET.
# With MIN_BET=1.0, STARTING_BANKROLL=20.0 makes safe mode stake $5.00.
STARTING_BANKROLL=20.0
MIN_BET=1.0
BOT_MODE=safe

# --- Dashboard / Railway ---
APP_ENV=development
DATABASE_URL=sqlite:///./polymarket_dashboard.db
# Production must use an Argon2 hash. Generate with:
# python -m app.security "your-password"
DASHBOARD_PASSWORD_HASH=
DASHBOARD_DEV_PASSWORD=admin
SESSION_SECRET=replace-with-at-least-32-random-characters
LIVE_TRADING_ENABLED=false
SERVICE_ROLE=web
TZ=Asia/Ho_Chi_Minh

# --- Endpoints ---
# Binance main API is geo-blocked in the US (HTTP 451); use the public market-data mirror.
BINANCE_BASE=https://data-api.binance.vision
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com
